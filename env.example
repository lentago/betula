# =============================================================================
# Firewalla → Grafana Cloud Loki Pipeline Configuration
#
# Copy this to .env and fill in your values:
#   cp env.example .env
#
# NEVER commit .env to git — it contains your access token.
# =============================================================================

# --- Grafana Cloud Loki (direct push) ----------------------------------------
# The Loki output ships Zeek DNS/conn/SSL + ACL events DIRECTLY to Grafana Cloud
# Loki (no LAN relay). All three values are required for the pipeline to ship.
# Host = the Loki push host (no scheme, no path), e.g. logs-prod-042.grafana.net
# User = the Grafana Cloud Loki instance/user ID (numeric)
# Token = a Grafana Cloud access-policy token with logs:write (glc_...)
GRAFANA_CLOUD_LOGS_HOST=logs-prod-XXX.grafana.net
GRAFANA_CLOUD_LOGS_USER=000000
GRAFANA_CLOUD_LOGS_TOKEN=glc-PASTE-YOUR-TOKEN-HERE
